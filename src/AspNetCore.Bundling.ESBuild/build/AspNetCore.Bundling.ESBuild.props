<Project>

  <PropertyGroup Condition="'$([System.Runtime.InteropServices.RuntimeInformation]::OSArchitecture)' == 'X64'">
    <ESBuildCommand Condition="$([MSBuild]::IsOSPlatform('Windows'))">$(MSBuildThisFileDirectory)..\runtimes\win-x64\esbuild.exe</ESBuildCommand>
    <ESBuildCommand Condition="$([MSBuild]::IsOSPlatform('Linux'))">$(MSBuildThisFileDirectory)..\runtimes\linux-x64\esbuild</ESBuildCommand>
    <ESBuildCommand Condition="$([MSBuild]::IsOSPlatform('OSX'))">$(MSBuildThisFileDirectory)..\runtimes\osx-x64\esbuild</ESBuildCommand>
  </PropertyGroup>

  <PropertyGroup Condition="'$([System.Runtime.InteropServices.RuntimeInformation]::OSArchitecture)' == 'Arm64'">
    <ESBuildCommand Condition="$([MSBuild]::IsOSPlatform('Windows'))">$(MSBuildThisFileDirectory)..\runtimes\win-arm64\esbuild.exe</ESBuildCommand>
    <ESBuildCommand Condition="$([MSBuild]::IsOSPlatform('Linux'))">$(MSBuildThisFileDirectory)..\runtimes\linux-arm64\esbuild</ESBuildCommand>
    <ESBuildCommand Condition="$([MSBuild]::IsOSPlatform('OSX'))">$(MSBuildThisFileDirectory)..\runtimes\osx-arm64\esbuild</ESBuildCommand>
  </PropertyGroup>

  <PropertyGroup>
    <ESBuildConfigFile Condition="'$(ESBuildConfigFile)' == ''">$(ProjectDir)esbuild.json</ESBuildConfigFile>
    <ESBuildTasksAssembly Condition="'$(ESBuildTasksAssembly)' == ''">$(MSBuildThisFileDirectory)..\tasks\AspNetCore.Bundling.ESBuild.Tasks.dll</ESBuildTasksAssembly>
    <ESBuildConfiguration Condition="'$(ESBuildConfiguration)' == ''">$(Configuration)</ESBuildConfiguration>
    <ESBuildConfiguration Condition="'$(ESBuildConfiguration)' == ''">Debug</ESBuildConfiguration>
  </PropertyGroup>

</Project>
