<Project>

  <ItemGroup>
    <UpToDateCheckInput Include="$(ESBuildConfigFile)" Condition="Exists('$(ESBuildConfigFile)')" />
    <UpToDateCheckInput Include="**/*.ts" />
    <UpToDateCheckInput Include="**/*.tsx" />
  </ItemGroup>

  <UsingTask TaskName="ESBuild.AspNetCore.Tasks.CompileESBuild"
             AssemblyFile="$(ESBuildTasksAssembly)"
             Condition="Exists('$(ESBuildTasksAssembly)')" />
  <UsingTask TaskName="ESBuild.AspNetCore.Tasks.CleanESBuildOutputs"
             AssemblyFile="$(ESBuildTasksAssembly)"
             Condition="Exists('$(ESBuildTasksAssembly)')" />

  <Target Name="CompileESBuild"
          BeforeTargets="Build;ResolveProjectStaticWebAssets"
          Condition="'$(DesignTimeBuild)' != 'true' AND Exists('$(ESBuildTasksAssembly)')">
    <CompileESBuild ESBuildFile="$(ESBuildConfigFile)"
                    Command="$(ESBuildCommand)"
                    Configuration="$(ESBuildConfiguration)"
                    InputFiles="@(UpToDateCheckInput)"
                    ProjectDirectory="$(MSBuildProjectDirectory)"
                    TargetFramework="$(TargetFramework)"
                    TargetFrameworks="$(TargetFrameworks)">
      <Output TaskParameter="GeneratedFiles"
              ItemName="ESBuildGeneratedFiles" />
    </CompileESBuild>

    <ItemGroup>
      <None Remove="@(ESBuildGeneratedFiles)" />
      <_NewESBuildGeneratedFiles Include="@(ESBuildGeneratedFiles)" Exclude="@(Content)" />
      <Content Include="@(_NewESBuildGeneratedFiles)" />
      <FileWrites Include="@(ESBuildGeneratedFiles)" />
    </ItemGroup>
  </Target>

  <Target Name="CleanESBuildOutputs"
          BeforeTargets="CoreClean"
          Condition="'$(DesignTimeBuild)' != 'true' AND Exists('$(ESBuildTasksAssembly)')">
    <CleanESBuildOutputs ProjectDirectory="$(MSBuildProjectDirectory)" />
  </Target>

</Project>
