<Project>

  <ItemGroup>
    <UpToDateCheckInput Include="$(ESBuildConfigFile)" Condition="Exists('$(ESBuildConfigFile)')" />
    <UpToDateCheckInput Include="**/*.ts" />
    <UpToDateCheckInput Include="**/*.tsx" />
  </ItemGroup>

  <UsingTask TaskName="ESBuild.AspNetCore.Tasks.CompileESBuild"
             AssemblyFile="$(ESBuildTasksAssembly)"
             Condition="Exists('$(ESBuildTasksAssembly)')" />
  <UsingTask TaskName="ESBuild.AspNetCore.Tasks.ResolveESBuildOutputs"
             AssemblyFile="$(ESBuildTasksAssembly)"
             Condition="Exists('$(ESBuildTasksAssembly)')" />
  <UsingTask TaskName="ESBuild.AspNetCore.Tasks.CleanESBuildOutputs"
             AssemblyFile="$(ESBuildTasksAssembly)"
             Condition="Exists('$(ESBuildTasksAssembly)')" />

  <Target Name="ResolveESBuildGeneratedContent"
          BeforeTargets="AssignTargetPaths;ResolveProjectStaticWebAssets"
          Condition="'$(DesignTimeBuild)' != 'true' AND Exists('$(ESBuildTasksAssembly)') AND Exists('$(ESBuildConfigFile)')">
    <ResolveESBuildOutputs ESBuildFile="$(ESBuildConfigFile)"
                           Configuration="$(ESBuildConfiguration)"
                           ProjectDirectory="$(MSBuildProjectDirectory)"
                           TargetFramework="$(TargetFramework)"
                           TargetFrameworks="$(TargetFrameworks)">
      <Output TaskParameter="OutputFiles"
              ItemName="_ESBuildConfiguredOutputFiles" />
    </ResolveESBuildOutputs>

    <ItemGroup>
      <_ESBuildConfiguredContent Include="@(_ESBuildConfiguredOutputFiles)"
                                 Condition="$([System.String]::Copy('%(Identity)').StartsWith('wwwroot\')) Or $([System.String]::Copy('%(Identity)').StartsWith('wwwroot/'))" />
      <None Remove="@(_ESBuildConfiguredContent)" />
      <Content Include="@(_ESBuildConfiguredContent)"
               Exclude="@(Content)" />
    </ItemGroup>
  </Target>

  <Target Name="CompileESBuild"
          BeforeTargets="Build;ResolveProjectStaticWebAssets"
          Condition="'$(DesignTimeBuild)' != 'true' AND Exists('$(ESBuildTasksAssembly)')">
    <CompileESBuild ESBuildFile="$(ESBuildConfigFile)"
                    Command="$(ESBuildCommand)"
                    Configuration="$(ESBuildConfiguration)"
                    InputFiles="@(UpToDateCheckInput)"
                    ProjectDirectory="$(MSBuildProjectDirectory)"
                    TargetFramework="$(TargetFramework)"
                    TargetFrameworks="$(TargetFrameworks)">
      <Output TaskParameter="GeneratedFiles"
              ItemName="ESBuildGeneratedFiles" />
    </CompileESBuild>

    <ItemGroup>
      <None Remove="@(ESBuildGeneratedFiles)" />
      <_NewESBuildGeneratedFiles Include="@(ESBuildGeneratedFiles)" Exclude="@(Content)" />
      <_NewESBuildGeneratedContentCandidate Include="$([MSBuild]::MakeRelative('$(MSBuildProjectDirectory)\', '%(_NewESBuildGeneratedFiles.Identity)'))"
                                            Condition="'%(_NewESBuildGeneratedFiles.Identity)' != ''" />
      <_NewESBuildGeneratedContent Include="@(_NewESBuildGeneratedContentCandidate)"
                                   Condition="!$([System.String]::Copy('%(Identity)').StartsWith('wwwroot\')) And !$([System.String]::Copy('%(Identity)').StartsWith('wwwroot/'))" />
      <Content Include="@(_NewESBuildGeneratedContent)" />
      <FileWrites Include="@(ESBuildGeneratedFiles)" />
    </ItemGroup>
  </Target>

  <Target Name="CleanESBuildOutputs"
          BeforeTargets="CoreClean"
          Condition="'$(DesignTimeBuild)' != 'true' AND Exists('$(ESBuildTasksAssembly)')">
    <CleanESBuildOutputs ProjectDirectory="$(MSBuildProjectDirectory)" />
  </Target>

</Project>
